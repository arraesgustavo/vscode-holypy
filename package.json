{
  "name": "holypy",
  "displayName": "holypy-support",
  "description": "HolyPy language support for VS Code.",
  "publisher": "gustavofernandes",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arraesgustavo/vscode-holypy.git"
  },
  "icon": "logos/logo_bg.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "keywords": [
    "holypy",
    "compiler",
    "unifei"
  ],
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "holypy",
        "aliases": [
          "HolyPy",
          "holypy"
        ],
        "extensions": [
          ".hpy"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./logos/logo_vscode_bg.png",
          "dark": "./logos/logo_vscode_bg.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "holypy",
        "scopeName": "source.holypy",
        "path": "./syntaxes/holypy.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "holypy",
        "path": "./snippets/holypy.json"
      }
    ]
  }
}
