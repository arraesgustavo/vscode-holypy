{
        "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
        "name": "HolyPy",
        "patterns": [
                {
                        "include": "#comments"
                },
                {
                        "include": "#directives"
                },
                {
                        "include": "#strings"
                },
                {
                        "include": "#chars"
                },
                {
                        "include": "#keywords_control"
                },
                {
                        "include": "#keywords_io_low"
                },
                {
                        "include": "#logical_operators"
                },
                {
                        "include": "#arithmetic_operators"
                },
                {
                        "include": "#comparison_operators"
                },
                {
                        "include": "#assignment_operators"
                },
                {
                        "include": "#booleans"
                },
                {
                        "include": "#types"
                },
                {
                        "include": "#numbers"
                },
                {
                        "include": "#delimiters"
                }
        ],
        "repository": {
                "comments": {
                        "patterns": [
                                {
                                        "name": "comment.line.number-sign.holypy",
                                        "match": "#.*$"
                                }
                        ]
                },
                "directives": {
                        "patterns": [
                                {
                                        "name": "meta.directive.holypy",
                                        "match": "![_A-Za-z][_A-Za-z0-9]*"
                                }
                        ]
                },
                "strings": {
                        "name": "string.quoted.double.holypy",
                        "begin": "\"",
                        "end": "\"",
                        "patterns": [
                                {
                                        "name": "constant.character.escape.holypy",
                                        "match": "\\\\."
                                }
                        ]
                },
                "chars": {
                        "name": "string.quoted.single.holypy",
                        "begin": "'",
                        "end": "'",
                        "patterns": [
                                {
                                        "name": "constant.character.escape.holypy",
                                        "match": "\\\\."
                                }
                        ]
                },
                "keywords_control": {
                        "patterns": [
                                {
                                        "name": "keyword.control.holypy",
                                        "match": "\\b(if|else|cycle|free|return)\\b"
                                }
                        ]
                },
                "keywords_io_low": {
                        "patterns": [
                                {
                                        "name": "keyword.other.holypy",
                                        "match": "\\b(let|fn|speak|receive|import|chain|unchain|asm)\\b"
                                }
                        ]
                },
                "logical_operators": {
                        "patterns": [
                                {
                                        "name": "keyword.control.holypy",
                                        "match": "\\b(and|or|not)\\b"
                                }
                        ]
                },
                "arithmetic_operators": {
                        "patterns": [
                                {
                                        "name": "keyword.operator.arithmetic.holypy",
                                        "match": "\\bmod\\b|\\+|-|\\*|/"
                                }
                        ]
                },
                "comparison_operators": {
                        "patterns": [
                                {
                                        "name": "keyword.operator.comparison.holypy",
                                        "match": "==|!=|>=|<=|>|<"
                                }
                        ]
                },
                "assignment_operators": {
                        "patterns": [
                                {
                                        "name": "keyword.operator.assignment.holypy",
                                        "match": "=(?!=)"
                                }
                        ]
                },
                "booleans": {
                        "patterns": [
                                {
                                        "name": "constant.language.boolean.holypy",
                                        "match": "\\b(true|false)\\b"
                                }
                        ]
                },
                "types": {
                        "patterns": [
                                {
                                        "name": "storage.type.holypy",
                                        "match": "\\b(i(8|16|32|64)|u(8|16|32|64)|f(32|64)|char|bool|u0)\\b"
                                }
                        ]
                },
                "numbers": {
                        "patterns": [
                                {
                                        "name": "constant.numeric.holypy",
                                        "match": "[+-]?(?:0[xX][0-9A-Fa-f]+|(?:[0-9]+(?:\\.[0-9]*)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?)"
                                }
                        ]
                },
                "delimiters": {
                        "patterns": [
                                {
                                        "name": "punctuation.separator.holypy",
                                        "match": "->|:|\\.|,|;"
                                }
                        ]
                }
        },
        "scopeName": "source.holypy"
}
